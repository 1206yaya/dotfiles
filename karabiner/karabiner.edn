      [:l ["open -a 'Visual Studio Code' $HOME/ghq/github.com/1206yaya/ai-agent-lemon "]]
      [:p ["open -a 'Visual Studio Code' $HOME/ghq/github.com/1206yaya/ai-agent-playground "]]
