      [:o ["open -a 'Cursor'"]]
      [:s ["open -a 'Safari'"]]
      [:l ["open -a 'Intellij IDEA CE'"]]
      [:g ["open -a 'Goland'"]]
      [:w ["open -a 'WebStorm'"]]
      [:y ["open -a 'PyCharm CE'"]]
      [:d ["open -a 'DBeaver'"]]
