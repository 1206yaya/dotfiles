noremap <Leader>AC :action ActivateCodotaToolWindow<CR>     " Codota を有効化（プラグイン必要）
noremap <Leader>cs :action CodotaLeanSearchCrossRefAction<CR> " Codota 機能（プラグイン必要）
noremap <Leader>csdn :action SearchByCSDN<CR>               " CSDN 検索（プラグイン必要）
noremap <Leader>rp :action ReplaceInPath<CR>                " パス内置換
noremap <Leader>dl :action DatabaseView.OpenDdlInConsole<CR> " DDL をコンソールで開く
noremap <Leader>ot :action Terminal.OpenInTerminal<CR>      " ターミナルで開く
noremap <Leader>sf :action SonarLint.AnalyzeFiles<CR>       " SonarLint による解析（プラグイン必要）
