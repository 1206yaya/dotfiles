noremap <Leader>TR :action antlr.TestRule<CR>
noremap <Leader>bc :action ByteCodeViewer<CR>               " バイトコードを表示
noremap <Leader>qq :action $TranslateTextComponent<CR>      " 翻訳（プラグインが必要）
noremap <Leader>tr :action $TranslateAndReplaceAction<CR>   " 翻訳して置換（プラグインが必要）
noremap <Leader>gfu :action GenerateFullRestUrl<CR>
noremap <Leader>atf :action AddToFavorites<CR>              " お気に入りに追加
noremap <Leader>cE :action CopyElement<CR>                  " 要素をコピー
noremap <Leader>nE :action NewElement<CR>                   " 要素を新規作成
noremap <Leader>de :action SafeDelete<CR>                   " 要素を安全に削除
nnoremap <CR><CR> :action ShowIntentionActions<CR>          " IDEA のインテンションを表示
nnoremap <Leader><CR> :action GotoNextError<CR>             " 次のエラーへ（インテンションと併用）
noremap <Leader>ps :action ShowProjectStructureSettings<CR> " プロジェクト設定を開く
noremap <Leader>ri :action RevealIn<CR>                     " ファイルをエクスプローラで表示
noremap <Leader>cu :action CloseAllUnmodifiedEditors<CR>    " 未変更のエディタを閉じる
