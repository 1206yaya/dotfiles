    "insert := ": {
        "prefix": "v",
        "description": "Variable declaration :=",
        "body": " := "
    },
    "insert name := value ": {
        "prefix": "vv",
        "description": "Variable declaration :=",
        "body": "${1:name} := ${0:value}"
    },
    ",": {
        "prefix": ",",
        "body": " <- "
    },
    "Test Function": {
        "prefix": "testfunc",
        "body": [
            "func Test${1:FunctionName}(t *testing.T) {",
            "\t$0",
            "}"
        ],
        "description": "Generate a Test function"
    },
    "max": {
        "prefix": "max",
        "body": [
            "func max(x, y int) int {",
            "   if x > y {",
            "      return x",
            "   }",
            "   return y",
            "}",
            ""
        ],
        "description": ""
    },
    "max function": {
        "prefix": "max",
        "body": [
            "func max(x int, others ...int) int {",
            "   res := x",
            "   for _, y := range others {",
            "       if y > res {",
            "           res = y",
            "       }",
            "   }",
            "   return res",
            "}"
        ],
        "description": "Snippet for a max function"
    },
    "min function": {
        "prefix": "min",
        "body": [
            "func min(x int, others ...int) int {",
            "   res := x",
            "   for _, y := range others {",
            "       if y < res {",
            "           res = y",
            "       }",
            "   }",
            "   return res",
            "}"
        ],
        "description": "Snippet for a min function"
    },
    "main run Fscan": {
        "prefix": "mainrunscan",
        "body": [
            "func run(in io.Reader, w io.Writer) {",
            "   out := bufio.NewWriter(w)",
            "   defer out.Flush()",
            "   var a, b, c int",
            "   fmt.Fscan(in, &a, &b, &c)",
            "",
            "}",
            "",
            "func main() {",
            "   run(bufio.NewReader(os.Stdin), os.Stdout)",
            "}",
            ""
        ],
        "description": ""
    }
}