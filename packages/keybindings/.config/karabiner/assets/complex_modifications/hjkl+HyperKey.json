{
  "title": "HyperKey + hjkl",
  "rules": [
    {
      "description": "HyperKey + hjkl",
      "manipulators": [
        {
          "from": {
            "key_code": ["h", "left_shift"],
            "modifiers": [
              "left_command",
              "left_control",
              "left_option"
            ]
          },
          "to": [
            {
              "key_code": "left_arrow"
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "j",
            "modifiers": {
              "mandatory": [
                "f20"
              ],
              "optional": [
                "left_shift",
                "left_option",
                "left_command"
              ]
            }
          },
          "to": [
            {
              "key_code": "down_arrow"
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "k",
            "modifiers": {
              "mandatory": [
                "f20"
              ],
              "optional": [
                "left_shift",
                "left_option",
                "left_command"
              ]
            }
          },
          "to": [
            {
              "key_code": "up_arrow"
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "l",
            "modifiers": {
              "mandatory": [
                "f20"
              ],
              "optional": [
                "left_shift",
                "left_option",
                "left_command"
              ]
            }
          },
          "to": [
            {
              "key_code": "right_arrow"
            }
          ],
          "type": "basic"
        }
      ]
    },
    {
      "description": "f20 + w = select word",
      "manipulators": [
        {
          "from": {
            "key_code": "w",
            "modifiers": {
              "mandatory": [
                "f20"
              ],
              "optional": [
                "left_shift",
                "left_option",
                "left_command"
              ]
            }
          },
          "to": [
            {
              "key_code": "left_arrow",
              "modifiers": [
                "left_shift",
                "left_option"
              ]
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_unless",
              "bundle_identifiers": [
                "com.googlecode.iterm2",
                "com.apple.Terminal"
              ]
            }
          ],
          "type": "basic"
        }
      ]
    },
    {
      "description": "f20 + u/y/c = 1del/del to head/del to end",
      "manipulators": [
        {
          "from": {
            "key_code": "u",
            "modifiers": {
              "mandatory": [
                "f20"
              ],
              "optional": [
                "left_shift",
                "left_option",
                "left_command"
              ]
            }
          },
          "to": [
            {
              "key_code": "h",
              "modifiers": [
                "f20"
              ]
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "i",
            "modifiers": {
              "mandatory": [
                "f20"
              ],
              "optional": [
                "left_shift",
                "left_option",
                "left_command"
              ]
            }
          },
          "to": [
            {
              "key_code": "k",
              "modifiers": [
                "f20"
              ]
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "c",
            "modifiers": {
              "mandatory": [
                "f20"
              ],
              "optional": [
                "left_shift",
                "left_option",
                "left_command"
              ]
            }
          },
          "to": [
            {
              "key_code": "a",
              "modifiers": [
                "left_shift",
                "f20"
              ]
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_unless",
              "bundle_identifiers": [
                "^com\\.apple\\.Terminal$",
                "^com\\.googlecode\\.iterm2$"
              ]
            }
          ],
          "type": "basic"
        }
      ]
    }
  ]
}