            "modifiers": {
              "mandatory": []
            },
            "simultaneous": [
              {
                "key_code": "o"
              },
              {
                "key_code": "n"
              }
            ],
            "simultaneous_options": {
              "key_down_order": "strict",
              "key_up_order": "strict_inverse",
              "to_after_key_up": [
                {
                  "set_variable": {
                    "name": "launcher_mode_v4",
                    "value": 0
                  }
                }
              ]
            }
          },
          "parameters": {
            "basic.simultaneous_threshold_milliseconds": 500
