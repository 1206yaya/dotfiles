{
  "title": "control + hjkl",
  "rules": [
    {
      "description": "control + hjkl",
      "manipulators": [
        {
          "from": {
            "key_code": "h",
            "modifiers": {
              "mandatory": [
                "left_control"
              ],
              "optional": [
                "left_shift",
                "left_option",
                "left_command"
              ]
            }
          },
          "to": [
            {
              "key_code": "left_arrow"
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "j",
            "modifiers": {
              "mandatory": [
                "left_control"
              ],
              "optional": [
                "left_shift",
                "left_option",
                "left_command"
              ]
            }
          },
          "to": [
            {
              "key_code": "down_arrow"
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "k",
            "modifiers": {
              "mandatory": [
                "left_control"
              ],
              "optional": [
                "left_shift",
                "left_option",
                "left_command"
              ]
            }
          },
          "to": [
            {
              "key_code": "up_arrow"
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "l",
            "modifiers": {
              "mandatory": [
                "left_control"
              ],
              "optional": [
                "left_shift",
                "left_option",
                "left_command"
              ]
            }
          },
          "to": [
            {
              "key_code": "right_arrow"
            }
          ],
          "type": "basic"
        }
      ]
    },
    {
      "description": "control + w = select word",
      "manipulators": [
        {
          "from": {
            "key_code": "w",
            "modifiers": {
              "mandatory": [
                "left_control"
              ],
              "optional": [
                "left_shift",
                "left_option",
                "left_command"
              ]
            }
          },
          "to": [
            {
              "key_code": "left_arrow",
              "modifiers": [
                "left_shift",
                "left_option"
              ]
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_unless",
              "bundle_identifiers": [
                "com.googlecode.iterm2",
                "com.apple.Terminal"
              ]
            }
          ],
          "type": "basic"
        }
      ]
    },
    {
      "description": "control + u/y/c = 1del/del to head/del to end",
      "manipulators": [
        {
          "from": {
            "key_code": "u",
            "modifiers": {
              "mandatory": [
                "left_control"
              ],
              "optional": [
                "left_shift",
                "left_option",
                "left_command"
              ]
            }
          },
          "to": [
            {
              "key_code": "h",
              "modifiers": [
                "left_control"
              ]
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "i",
            "modifiers": {
              "mandatory": [
                "left_control"
              ],
              "optional": [
                "left_shift",
                "left_option",
                "left_command"
              ]
            }
          },
          "to": [
            {
              "key_code": "k",
              "modifiers": [
                "left_control"
              ]
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "c",
            "modifiers": {
              "mandatory": [
                "left_control"
              ],
              "optional": [
                "left_shift",
                "left_option",
                "left_command"
              ]
            }
          },
          "to": [
            {
              "key_code": "a",
              "modifiers": [
                "left_shift",
                "left_control"
              ]
            }
          ],
          "type": "basic"
        }
      ]
    }
  ]
}