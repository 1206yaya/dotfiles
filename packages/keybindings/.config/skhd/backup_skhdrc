
#! reload `skhd --reload`
### Debug 
# yabai -m config debug_output on
# tail -f /tmp/yabai_$USER.err.log
# tail -f /tmp/yabai_$USER.out.log
###
# move window
# ウィンドウのフォーカス管理
alt - h : yabai -m window --focus west  # 左のウィンドウにフォーカスを移動
alt - j : yabai -m window --focus south # 下のウィンドウにフォーカスを移動
alt - k : yabai -m window --focus north # 上のウィンドウにフォーカスを移動
alt - l : yabai -m window --focus east  # 右のウィンドウにフォーカスを移動

# ウィンドウの移動
shift + alt - h : yabai -m window --warp west  # 現在のウィンドウを左に移動
shift + alt - j : yabai -m window --warp south # 現在のウィンドウを下に移動
shift + alt - k : yabai -m window --warp north # 現在のウィンドウを上に移動
shift + alt - l : yabai -m window --warp east  # 現在のウィンドウを右に移動

# ウィンドウのリサイズ
ctrl + alt - h : yabai -m window --resize left:20:0    # ウィンドウを左にリサイズ
ctrl + alt - j : yabai -m window --resize bottom:0:20 # ウィンドウを下にリサイズ
ctrl + alt - k : yabai -m window --resize top:0:-20   # ウィンドウを上にリサイズ
ctrl + alt - l : yabai -m window --resize right:20:0  # ウィンドウを右にリサイズ

# ウィンドウの作成と閉鎖
alt - n : yabai -m window --space next      # 新しいスペースに移動
alt - p : yabai -m window --space prev      # 前のスペースに移動
alt - c : yabai -m window --close           # 現在のウィンドウを閉じる

# スペース（デスクトップ）の管理
ctrl + alt - left : yabai -m space --focus prev # 前のスペースにフォーカスを移動
ctrl + alt - right : yabai -m space --focus next # 次のスペースにフォーカスを移動




